import { VerticalBox, HorizontalBox, Button, ComboBox } from "std-widgets.slint";

export component MainWindow inherits Window {
    title: "Operation Logger";
    width: 680px;
    height: 360px;

    in-out property <[string]> app_items: [];
    in-out property <int> selected_index: -1;
    in-out property <bool> logging: false;
    in-out property <bool> has_log_dir: false;
    in-out property <string> selected_title: "-";
    in-out property <string> selected_process_name: "-";
    in-out property <string> selected_process_id: "-";
    in-out property <string> status_text: "Ready";

    callback refresh_clicked();
    callback selection_changed(index: int);
    callback start_clicked();
    callback stop_clicked();
    callback open_folder_clicked();

    VerticalBox {
        padding: 12px;
        spacing: 10px;

        HorizontalBox {
            spacing: 8px;
            app_selector := ComboBox {
                model: root.app_items;
                current-index <=> root.selected_index;
                enabled: !root.logging;
                selected => {
                    root.selection_changed(app_selector.current-index);
                }
            }
            Button {
                text: "Refresh";
                clicked => { root.refresh_clicked(); }
            }
        }

        Rectangle {
            border-width: 1px;
            border-color: #cccccc;
            border-radius: 4px;
            height: 120px;

            VerticalBox {
                padding: 10px;
                spacing: 6px;
                Text { text: "title: " + root.selected_title; }
                Text { text: "process_name: " + root.selected_process_name; }
                Text { text: "process_id: " + root.selected_process_id; }
            }
        }

        HorizontalBox {
            spacing: 8px;
            Button {
                text: "Start";
                enabled: !root.logging && root.selected_index >= 0;
                clicked => { root.start_clicked(); }
            }
            Button {
                text: "Stop";
                enabled: root.logging;
                clicked => { root.stop_clicked(); }
            }
            Button {
                text: "Open Folder";
                enabled: root.has_log_dir;
                clicked => { root.open_folder_clicked(); }
            }
        }

        Rectangle {
            border-width: 1px;
            border-color: #cccccc;
            border-radius: 4px;
            height: 72px;
            Text {
                text: root.status_text;
                wrap: word-wrap;
                vertical-alignment: center;
                horizontal-alignment: left;
            }
        }
    }
}
